generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Visit {
  id        String   @id @default(uuid())
  page      String
  country   String?
  city      String?
  duration  Int?
  createdAt DateTime @default(now()) @db.Timestamp(6)

  @@index([page])
  @@index([createdAt])
}
